                    { "id": "cb3", "type": "ref", "ref": "daisyui:Checkbox", "props": { "variant": "accent" } },
                    { "id": "cb4", "type": "ref", "ref": "daisyui:Checkbox", "props": { "variant": "success" } }
                  ]
                }
              ]
            },
            {
              "id": "sec-rd", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-rd", "type": "text", "content": "Radio", "fontSize": 14, "fontWeight": 700, "color": "#059669" },
                {
                  "id": "r-rd", "type": "frame", "layout": "horizontal", "gap": 12, "alignItems": "center",
                  "children": [
                    { "id": "rd1", "type": "ref", "ref": "daisyui:Radio", "props": { "variant": "primary" } },
                    { "id": "rd2", "type": "ref", "ref": "daisyui:Radio", "props": { "variant": "secondary" } },
                    { "id": "rd3", "type": "ref", "ref": "daisyui:Radio", "props": { "variant": "accent" } }
                  ]
                }
              ]
            },
            {
              "id": "sec-tg", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-tg", "type": "text", "content": "Toggle", "fontSize": 14, "fontWeight": 700, "color": "#059669" },
                {
                  "id": "r-tg", "type": "frame", "layout": "horizontal", "gap": 12, "alignItems": "center",
                  "children": [
                    { "id": "tg1", "type": "ref", "ref": "daisyui:Toggle", "props": { "variant": "primary" } },
                    { "id": "tg2", "type": "ref", "ref": "daisyui:Toggle", "props": { "variant": "secondary" } },
                    { "id": "tg3", "type": "ref", "ref": "daisyui:Toggle", "props": { "variant": "success" } }
                  ]
                }
              ]
            },
            {
              "id": "sec-rng", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-rng", "type": "text", "content": "Range", "fontSize": 14, "fontWeight": 700, "color": "#059669" },
                { "id": "c-rng", "type": "ref", "ref": "daisyui:Range", "props": { "variant": "primary" } }
              ]
            },
            {
              "id": "sec-rat", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-rat", "type": "text", "content": "Rating", "fontSize": 14, "fontWeight": 700, "color": "#059669" },
                { "id": "c-rat", "type": "ref", "ref": "daisyui:Rating" }
              ]
            },
            {
              "id": "sec-fi", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
