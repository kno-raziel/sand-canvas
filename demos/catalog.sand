{
  "version": 1,
  "name": "daisyUI 5 — Complete Catalog",
  "children": [
    {
      "type": "frame",
      "name": "1 — Actions",
      "id": "scr-actions",
      "x": 100,
      "y": 100,
      "width": 900,
      "height": 1100,
      "children": [
        {
          "id": "a-hdr", "type": "frame", "layout": "horizontal", "width": "fill_container", "height": 56,
          "padding": [12, 24, 12, 24], "fill": "#6366f1", "alignItems": "center",
          "children": [
            { "id": "a-t", "type": "text", "content": "1. ACTIONS (4 components)", "fontSize": 18, "fontWeight": 700, "color": "#ffffff" }
          ]
        },
        {
          "id": "a-body", "type": "frame", "layout": "vertical", "width": "fill_container", "padding": 24, "gap": 16,
          "children": [
            {
              "id": "sec-btn", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 12,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-btn", "type": "text", "content": "Button", "fontSize": 14, "fontWeight": 700, "color": "#6366f1" },
                {
                  "id": "r-btn1", "type": "frame", "layout": "horizontal", "gap": 8, "alignItems": "center", "flexWrap": "wrap",
                  "children": [
                    { "id": "b1", "type": "ref", "ref": "daisyui:Button", "props": { "label": "Primary", "variant": "primary" } },
                    { "id": "b2", "type": "ref", "ref": "daisyui:Button", "props": { "label": "Secondary", "variant": "secondary" } },
                    { "id": "b3", "type": "ref", "ref": "daisyui:Button", "props": { "label": "Accent", "variant": "accent" } },
                    { "id": "b4", "type": "ref", "ref": "daisyui:Button", "props": { "label": "Info", "variant": "info" } },
                    { "id": "b5", "type": "ref", "ref": "daisyui:Button", "props": { "label": "Success", "variant": "success" } },
                    { "id": "b6", "type": "ref", "ref": "daisyui:Button", "props": { "label": "Warning", "variant": "warning" } },
                    { "id": "b7", "type": "ref", "ref": "daisyui:Button", "props": { "label": "Error", "variant": "error" } },
                    { "id": "b8", "type": "ref", "ref": "daisyui:Button", "props": { "label": "Ghost", "variant": "ghost" } },
                    { "id": "b9", "type": "ref", "ref": "daisyui:Button", "props": { "label": "Link", "variant": "link" } }
                  ]
                },
                {
                  "id": "r-btn2", "type": "frame", "layout": "horizontal", "gap": 8, "alignItems": "center",
                  "children": [
                    { "id": "b10", "type": "ref", "ref": "daisyui:Button", "props": { "label": "Outline", "variant": "primary", "outline": true } },
                    { "id": "b11", "type": "ref", "ref": "daisyui:Button", "props": { "label": "Wide", "variant": "primary", "wide": true } },
                    { "id": "b12", "type": "ref", "ref": "daisyui:Button", "props": { "label": "XS", "size": "xs" } },
                    { "id": "b13", "type": "ref", "ref": "daisyui:Button", "props": { "label": "SM", "size": "sm" } },
                    { "id": "b14", "type": "ref", "ref": "daisyui:Button", "props": { "label": "LG", "size": "lg" } }
                  ]
                }
              ]
            },
            {
              "id": "sec-drop", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-drop", "type": "text", "content": "Dropdown", "fontSize": 14, "fontWeight": 700, "color": "#6366f1" },
                { "id": "c-drop", "type": "ref", "ref": "daisyui:Dropdown", "props": { "label": "Click me", "item1": "Item 1", "item2": "Item 2" } }
              ]
            },
            {
              "id": "sec-modal", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-mod", "type": "text", "content": "Modal", "fontSize": 14, "fontWeight": 700, "color": "#6366f1" },
                { "id": "c-mod", "type": "ref", "ref": "daisyui:Modal", "props": { "title": "Confirm Action", "description": "Are you sure?", "cancelLabel": "Cancel", "confirmLabel": "Yes" } }
              ]
            },
            {
              "id": "sec-swap", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-swp", "type": "text", "content": "Swap", "fontSize": 14, "fontWeight": 700, "color": "#6366f1" },
                { "id": "c-swp", "type": "ref", "ref": "daisyui:Swap", "props": { "onContent": "🌙", "offContent": "☀️" } }
              ]
            }
          ]
        }
      ]
    },

    {
      "type": "frame",
      "name": "2 — Data Display",
      "id": "scr-data",
      "x": 1100,
      "y": 100,
      "width": 900,
      "height": 2600,
      "children": [
        {
          "id": "d-hdr", "type": "frame", "layout": "horizontal", "width": "fill_container", "height": 56,
          "padding": [12, 24, 12, 24], "fill": "#0891b2", "alignItems": "center",
          "children": [
            { "id": "d-t", "type": "text", "content": "2. DATA DISPLAY (15 components)", "fontSize": 18, "fontWeight": 700, "color": "#ffffff" }
          ]
        },
        {
          "id": "d-body", "type": "frame", "layout": "vertical", "width": "fill_container", "padding": 24, "gap": 16,
          "children": [
            {
              "id": "sec-acc", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-acc", "type": "text", "content": "Accordion", "fontSize": 14, "fontWeight": 700, "color": "#0891b2" },
                { "id": "c-acc", "type": "ref", "ref": "daisyui:Accordion", "props": { "title": "Click to expand", "description": "Hidden content here." } }
              ]
            },
            {
              "id": "sec-av", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-av", "type": "text", "content": "Avatar", "fontSize": 14, "fontWeight": 700, "color": "#0891b2" },
                {
                  "id": "r-av", "type": "frame", "layout": "horizontal", "gap": 12, "alignItems": "center",
                  "children": [
                    { "id": "av1", "type": "ref", "ref": "daisyui:Avatar", "props": { "initials": "JD" } },
                    { "id": "av2", "type": "ref", "ref": "daisyui:Avatar", "props": { "initials": "AB" } },
                    { "id": "av3", "type": "ref", "ref": "daisyui:Avatar", "props": { "initials": "XY" } }
                  ]
                }
              ]
            },
            {
              "id": "sec-bdg", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-bdg", "type": "text", "content": "Badge", "fontSize": 14, "fontWeight": 700, "color": "#0891b2" },
                {
                  "id": "r-bdg", "type": "frame", "layout": "horizontal", "gap": 8, "alignItems": "center", "flexWrap": "wrap",
                  "children": [
                    { "id": "bg1", "type": "ref", "ref": "daisyui:Badge", "props": { "label": "Default" } },
                    { "id": "bg2", "type": "ref", "ref": "daisyui:Badge", "props": { "label": "Primary", "variant": "primary" } },
                    { "id": "bg3", "type": "ref", "ref": "daisyui:Badge", "props": { "label": "Accent", "variant": "accent" } },
                    { "id": "bg4", "type": "ref", "ref": "daisyui:Badge", "props": { "label": "Success", "variant": "success" } },
                    { "id": "bg5", "type": "ref", "ref": "daisyui:Badge", "props": { "label": "Warning", "variant": "warning" } },
                    { "id": "bg6", "type": "ref", "ref": "daisyui:Badge", "props": { "label": "Error", "variant": "error" } }
                  ]
                }
              ]
            },
            {
              "id": "sec-crd", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-crd", "type": "text", "content": "Card", "fontSize": 14, "fontWeight": 700, "color": "#0891b2" },
                {
                  "id": "r-crd", "type": "frame", "layout": "horizontal", "gap": 12,
                  "children": [
                    { "id": "crd1", "type": "ref", "ref": "daisyui:Card", "props": { "title": "Default", "description": "A card with shadow." } },
                    { "id": "crd2", "type": "ref", "ref": "daisyui:Card", "props": { "title": "Bordered", "description": "With border.", "bordered": true } }
                  ]
                }
              ]
            },
            {
              "id": "sec-chat", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-chat", "type": "text", "content": "Chat Bubble", "fontSize": 14, "fontWeight": 700, "color": "#0891b2" },
                { "id": "c-chat", "type": "ref", "ref": "daisyui:Chat", "props": { "sender": "Alice", "message": "Hello! 👋", "timestamp": "2m ago" } }
              ]
            },
            {
              "id": "sec-col", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-col", "type": "text", "content": "Collapse", "fontSize": 14, "fontWeight": 700, "color": "#0891b2" },
                { "id": "c-col", "type": "ref", "ref": "daisyui:Collapse", "props": { "title": "Toggle me", "description": "Hidden content.", "arrow": true } }
              ]
            },
            {
              "id": "sec-cd", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-cd", "type": "text", "content": "Countdown", "fontSize": 14, "fontWeight": 700, "color": "#0891b2" },
                { "id": "c-cd", "type": "ref", "ref": "daisyui:Countdown", "props": { "value": "42" } }
              ]
            },
            {
              "id": "sec-kbd", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-kbd", "type": "text", "content": "Kbd", "fontSize": 14, "fontWeight": 700, "color": "#0891b2" },
                {
                  "id": "r-kbd", "type": "frame", "layout": "horizontal", "gap": 8,
                  "children": [
                    { "id": "k1", "type": "ref", "ref": "daisyui:Kbd", "props": { "key": "⌘" } },
                    { "id": "k2", "type": "ref", "ref": "daisyui:Kbd", "props": { "key": "K" } },
                    { "id": "k3", "type": "ref", "ref": "daisyui:Kbd", "props": { "key": "Shift" } },
                    { "id": "k4", "type": "ref", "ref": "daisyui:Kbd", "props": { "key": "Enter" } }
                  ]
                }
              ]
            },
            {
              "id": "sec-lst", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-lst", "type": "text", "content": "List", "fontSize": 14, "fontWeight": 700, "color": "#0891b2" },
                { "id": "c-lst", "type": "ref", "ref": "daisyui:List", "props": { "item1": "First item", "item2": "Second item", "item3": "Third item" } }
              ]
            },
            {
              "id": "sec-stat", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-stat", "type": "text", "content": "Stat", "fontSize": 14, "fontWeight": 700, "color": "#0891b2" },
                {
                  "id": "r-stat", "type": "frame", "layout": "horizontal", "gap": 16,
                  "children": [
                    { "id": "st1", "type": "ref", "ref": "daisyui:Stat", "props": { "title": "Downloads", "value": "31K", "description": "Jan 1 — Feb 1" } },
                    { "id": "st2", "type": "ref", "ref": "daisyui:Stat", "props": { "title": "Users", "value": "4,200", "description": "↗︎ 400 (22%)" } }
                  ]
                }
              ]
            },
            {
              "id": "sec-sts", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-sts", "type": "text", "content": "Status", "fontSize": 14, "fontWeight": 700, "color": "#0891b2" },
                {
                  "id": "r-sts", "type": "frame", "layout": "horizontal", "gap": 12, "alignItems": "center",
                  "children": [
                    { "id": "ss1", "type": "ref", "ref": "daisyui:Status", "props": { "variant": "success" } },
                    { "id": "ss2", "type": "ref", "ref": "daisyui:Status", "props": { "variant": "warning" } },
                    { "id": "ss3", "type": "ref", "ref": "daisyui:Status", "props": { "variant": "error" } },
                    { "id": "ss4", "type": "ref", "ref": "daisyui:Status", "props": { "variant": "info", "animate": true } }
                  ]
                }
              ]
            },
            {
              "id": "sec-tbl", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-tbl", "type": "text", "content": "Table", "fontSize": 14, "fontWeight": 700, "color": "#0891b2" },
                { "id": "c-tbl", "type": "ref", "ref": "daisyui:Table", "props": { "col1": "Name", "col2": "Role", "col3": "Status", "row1col1": "Alice", "row1col2": "Engineer", "row1col3": "Active", "row2col1": "Bob", "row2col2": "Designer", "row2col3": "Away" } }
              ]
            },
            {
              "id": "sec-tl", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-tl", "type": "text", "content": "Timeline", "fontSize": 14, "fontWeight": 700, "color": "#0891b2" },
                { "id": "c-tl", "type": "ref", "ref": "daisyui:Timeline", "props": { "step1": "Register", "step2": "Verify", "step3": "Done" } }
              ]
            },
            {
              "id": "sec-diff", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-diff", "type": "text", "content": "Diff", "fontSize": 14, "fontWeight": 700, "color": "#0891b2" },
                { "id": "c-diff", "type": "ref", "ref": "daisyui:Diff", "props": { "before": "Before", "after": "After" } }
              ]
            },
            {
              "id": "sec-car", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-car", "type": "text", "content": "Carousel", "fontSize": 14, "fontWeight": 700, "color": "#0891b2" },
                { "id": "c-car", "type": "ref", "ref": "daisyui:Carousel", "props": { "slide1": "Slide 1", "slide2": "Slide 2", "slide3": "Slide 3" } }
              ]
            }
          ]
        }
      ]
    },

    {
      "type": "frame",
      "name": "3 — Data Input",
      "id": "scr-input",
      "x": 2100,
      "y": 100,
      "width": 900,
      "height": 1600,
      "children": [
        {
          "id": "i-hdr", "type": "frame", "layout": "horizontal", "width": "fill_container", "height": 56,
          "padding": [12, 24, 12, 24], "fill": "#059669", "alignItems": "center",
          "children": [
            { "id": "i-t", "type": "text", "content": "3. DATA INPUT (13 components)", "fontSize": 18, "fontWeight": 700, "color": "#ffffff" }
          ]
        },
        {
          "id": "i-body", "type": "frame", "layout": "vertical", "width": "fill_container", "padding": 24, "gap": 16,
          "children": [
            {
              "id": "sec-inp", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-inp", "type": "text", "content": "Text Input", "fontSize": 14, "fontWeight": 700, "color": "#059669" },
                {
                  "id": "r-inp", "type": "frame", "layout": "horizontal", "gap": 12,
                  "children": [
                    { "id": "inp1", "type": "ref", "ref": "daisyui:Input", "props": { "bordered": true } },
                    { "id": "inp2", "type": "ref", "ref": "daisyui:Input", "props": { "variant": "primary", "bordered": true } }
                  ]
                }
              ]
            },
            {
              "id": "sec-ta", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
              "padding": 16, "stroke": "#e2e8f0", "strokeWidth": 1, "cornerRadius": 8,
              "children": [
                { "id": "l-ta", "type": "text", "content": "Textarea", "fontSize": 14, "fontWeight": 700, "color": "#059669" },
                { "id": "c-ta", "type": "ref", "ref": "daisyui:Textarea", "props": { "bordered": true } }
              ]
            },
            {
              "id": "sec-sel", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
