              "children": [
                { "id": "l-sel", "type": "text", "content": "Select", "fontSize": 14, "fontWeight": 700, "color": "#059669" },
                { "id": "c-sel", "type": "ref", "ref": "daisyui:Select", "props": { "option1": "Option 1", "option2": "Option 2", "option3": "Option 3", "bordered": true } }
              ]
            },
            {
              "id": "sec-cb", "type": "frame", "layout": "vertical", "width": "fill_container", "gap": 8,
