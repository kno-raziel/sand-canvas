{
  "name": "@sand/mcp-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "sand-mcp": "./src/index.ts"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
