    "check:fix": "biome check --write ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@sand/core": "workspace:*",
    "react": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
